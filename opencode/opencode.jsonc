{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "threshold": 75,
  },
  "agent": {
  },
  "formatter": {
    "biome": {
      "command": ["bunx", "biome", "format", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc"]
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
